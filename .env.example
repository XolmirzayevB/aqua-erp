# Database
DATABASE_URL="postgresql://aqua_user:aqua_pass@localhost:5432/aqua_erp?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-very-long-random-secret-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-very-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NODE_ENV="development"
API_PORT=3001
FRONTEND_URL="http://localhost:3000"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3001"

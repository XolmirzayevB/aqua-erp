# ─── Production muhit ─────────────────────────────────────────────────────────
# Bu faylni .env.production ga nusxalang va qiymatlarni to'ldiring
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

# Database
POSTGRES_USER=aqua_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=aqua_erp

# JWT — uzun, tasodifiy maxfiy kalitlar (masalan: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_64_char_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_another_64_char_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Domen / URL (Nginx orqali bir xil domen)
# Masalan: https://erp.sizningdomeningiz.uz
PUBLIC_URL=http://localhost
FRONTEND_URL=http://localhost

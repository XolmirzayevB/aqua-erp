generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  OPERATOR
  DRIVER
}

enum OrderStatus {
  NEW
  PROCESSING
  ASSIGNED
  DELIVERED
  CANCELLED
}

enum PaymentType {
  CASH
  CARD
  DEBT
}

enum TransactionType {
  INCOME
  EXPENSE
  SALARY
  SUPPLIER_PAYMENT
}

enum PaymentMethod {
  CASH
  CARD
}

enum InventoryType {
  FULL_BOTTLE
  EMPTY_BOTTLE
  BROKEN_BOTTLE
  LOST_BOTTLE
}

enum InventoryActionType {
  INTAKE
  DELIVERY
  RETURN
  ADJUSTMENT
  BROKEN
  LOST
}

enum DriverSessionStatus {
  OPEN
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  phone        String   @unique @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(OPERATOR)
  isActive     Boolean  @default(true) @map("is_active")
  refreshToken String?  @map("refresh_token") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  orders         Order[]        @relation("DriverOrders")
  createdOrders  Order[]        @relation("CreatedOrders")
  driverSessions DriverSession[]
  transactions   Transaction[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  createdCustomers Customer[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id               String   @id @default(uuid())
  name             String   @db.VarChar(100)
  phone            String   @db.VarChar(20)
  phone2           String?  @db.VarChar(20)
  address          String   @db.Text
  zone             String?  @db.VarChar(50)
  locationLink     String?  @map("location_link") @db.Text
  lat              Decimal? @db.Decimal(10, 8)
  lng              Decimal? @db.Decimal(11, 8)
  notes            String?  @db.Text
  bottlesOwned     Int      @default(0) @map("bottles_owned")
  bottlesGiven     Int      @default(0) @map("bottles_given")
  bottlesReturned  Int      @default(0) @map("bottles_returned")
  balance          Decimal  @default(0) @db.Decimal(12, 2)
  isActive         Boolean  @default(true) @map("is_active")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  createdBy    User          @relation(fields: [createdById], references: [id])
  orders       Order[]
  transactions Transaction[]
  payments     Payment[]

  @@index([phone])
  @@index([name])
  @@index([isActive])
  @@map("customers")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id               String      @id @default(uuid())
  orderNumber      String      @unique @map("order_number") @db.VarChar(20)
  customerId       String      @map("customer_id")
  driverId         String?     @map("driver_id")
  createdById      String      @map("created_by_id")
  quantity         Int
  pricePerUnit     Decimal     @map("price_per_unit") @db.Decimal(10, 2)
  refillCount      Int         @default(0) @map("refill_count")
  newBottles       Int         @default(0) @map("new_bottles")
  refillPrice      Decimal     @default(0) @map("refill_price") @db.Decimal(10, 2)
  newBottlePrice   Decimal     @default(0) @map("new_bottle_price") @db.Decimal(10, 2)
  totalAmount      Decimal     @map("total_amount") @db.Decimal(12, 2)
  bottlesReturned  Int         @default(0) @map("bottles_returned")
  paymentType      PaymentType @map("payment_type")
  status           OrderStatus @default(NEW)
  notes            String?     @db.Text
  deliveredAt      DateTime?   @map("delivered_at") @db.Timestamptz
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  customer     Customer      @relation(fields: [customerId], references: [id])
  driver       User?         @relation("DriverOrders", fields: [driverId], references: [id])
  createdBy    User          @relation("CreatedOrders", fields: [createdById], references: [id])
  transactions Transaction[]

  @@index([status])
  @@index([customerId])
  @@index([driverId])
  @@index([createdAt])
  @@map("orders")
}

// ─── Driver Sessions ─────────────────────────────────────────────────────────

model DriverSession {
  id              String             @id @default(uuid())
  driverId        String             @map("driver_id")
  date            DateTime           @db.Date
  bottlesTaken    Int                @default(0) @map("bottles_taken")
  emptyTaken      Int                @default(0) @map("empty_taken")
  bottlesSold     Int                @default(0) @map("bottles_sold")
  emptyReturned   Int                @default(0) @map("empty_returned")
  cashCollected   Decimal            @default(0) @map("cash_collected") @db.Decimal(12, 2)
  cardCollected   Decimal            @default(0) @map("card_collected") @db.Decimal(12, 2)
  status          DriverSessionStatus @default(OPEN)
  notes           String?            @db.Text
  closedAt        DateTime?          @map("closed_at") @db.Timestamptz
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  driver User @relation(fields: [driverId], references: [id])

  @@unique([driverId, date])
  @@index([driverId])
  @@index([date])
  @@map("driver_sessions")
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model Inventory {
  id        String        @id @default(uuid())
  type      InventoryType @unique
  quantity  Int           @default(0)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  actions InventoryAction[]

  @@map("inventory")
}

model InventoryAction {
  id           String             @id @default(uuid())
  inventoryId  String             @map("inventory_id")
  actionType   InventoryActionType @map("action_type")
  quantity     Int
  description  String?            @db.Text
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@index([inventoryId])
  @@index([createdAt])
  @@map("inventory_actions")
}

// ─── Settings (sozlanadigan narxlar, hududlar) ─────────────────────────────────

model Setting {
  key       String   @id @db.VarChar(50)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}

// ─── Finance ─────────────────────────────────────────────────────────────────

model Transaction {
  id            String          @id @default(uuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  paymentMethod PaymentMethod   @map("payment_method")
  category      String?         @db.VarChar(100)
  description   String?         @db.Text
  orderId       String?         @map("order_id")
  customerId    String?         @map("customer_id")
  createdById   String          @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz

  order      Order?    @relation(fields: [orderId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdBy  User      @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([customerId])
  @@index([orderId])
  @@index([createdAt])
  @@map("transactions")
}

model Payment {
  id          String        @id @default(uuid())
  customerId  String        @map("customer_id")
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("payments")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  body      String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  data      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id        BigInt      @id @default(autoincrement())
  userId    String?     @map("user_id")
  action    AuditAction
  entity    String      @db.VarChar(50)
  entityId  String?     @map("entity_id") @db.Uuid
  oldData   Json?       @map("old_data")
  newData   Json?       @map("new_data")
  ipAddress String?     @map("ip_address") @db.VarChar(45)
  userAgent String?     @map("user_agent") @db.Text
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
